# Build PATH
_myPaths=(
    "${HOME}/.local/bin"
    "/usr/local/bin"
    "/opt/homebrew/bin"
    "/home/linuxbrew/.linuxbrew/bin"
    "/home/linuxbrew/.linuxbrew/sbin"
    "{{ .directories.user_bin_dir }}"
    "{{ .xdgDataDir }}/cargo/bin"
    "/usr/bin/snap"
    # mise shims, so mise-managed tools are on PATH before third-party init files
    # load (e.g. atuin.sh, which runs before mise.sh activates mise interactively)
    "{{ .xdgDataDir }}/mise/shims"
)

for _path in "${_myPaths[@]}"; do
    if [[ -d ${_path} ]]; then
        if ! printf "%s" "${_path}" | grep -q "${PATH}"; then
            PATH="${_path}:${PATH}"
        fi
    fi
done

unset _myPaths _path
