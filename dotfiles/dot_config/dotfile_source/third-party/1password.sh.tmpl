{{- if lookPath "op" -}}

# 1Password CLI completions, baked at chezmoi apply time so we don't fork `op`
# on every shell startup.
if [[ -n ${ZSH_NAME} ]]; then
{{ output "op" "completion" "zsh" | trim }}
    compdef _op op
elif [[ -n ${BASH} ]]; then
{{ output "op" "completion" "bash" | trim }}
fi

{{- end }}
