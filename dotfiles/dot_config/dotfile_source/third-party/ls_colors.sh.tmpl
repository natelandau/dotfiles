{{- if lookPath "vivid" -}}
# LS_COLORS is generated by `vivid` at chezmoi apply time and baked in as a
# literal so we don't fork vivid on every shell startup.
export LS_COLORS={{ output "vivid" "generate" "one-dark" | trim | squote }}

# zsh completion colors derive from LS_COLORS, so this must run after LS_COLORS
# is set. It lives here (not 001-options.zsh) because that file loads earlier,
# before LS_COLORS exists.
if [[ -n ${ZSH_NAME} ]]; then
    zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
fi
{{- end }}
