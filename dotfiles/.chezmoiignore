# push/pull are git-friendly fallbacks, only managed when 'gx' is absent.
{{ if lookPath "gx" }}
bin/push
bin/pull
{{ end }}

{{ if not (and (lookPath "uv") .dev_computer) }}
bin/uvupgrade
{{ end }}

# Only install dcp when docker is present and it isn't already in ~/.local/bin.
{{ if not (and (lookPath "docker") (not (joinPath .chezmoi.homeDir ".local/bin/dcp" | stat))) }}
bin/dcp
{{ end }}

