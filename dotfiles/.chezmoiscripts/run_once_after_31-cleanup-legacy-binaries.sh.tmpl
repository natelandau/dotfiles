{{- if and (eq .chezmoi.os "linux") (not .is_ci_workflow) -}}
#!/usr/bin/env bash

{{ template "shared_script_utils.bash" . }}

# One-time migration. The previous install-binary.py installed these tools either
# as .deb packages (via dpkg) or as plain files in ~/.local/bin. mise now owns
# them, so remove the legacy copies to keep them from shadowing mise's versions.
# Runs once per host (run_once); mise's shims still take PATH priority regardless.

header "Removing legacy binary installs now managed by mise"

# Plain-file copies dropped into ~/.local/bin by the old tarball installer. Both
# the executable name and the package name are listed because the old installer
# named the file after the package, not always the executable.
legacy_files=(bottom btm delta doggo lazygit rip zoxide)
for _file in "${legacy_files[@]}"; do
    _target="${HOME}/.local/bin/${_file}"
    # Only remove real files; mise keeps its binaries under its own shims/installs dirs.
    if [[ -f ${_target} && ! -L ${_target} ]]; then
        info "Removing ${_target}"
        rm -f "${_target}"
    fi
done

# .deb packages installed via dpkg by the old installer. dpkg -l guards against
# packages that were never installed (e.g. tarball-only tools).
legacy_packages=(bottom git-delta zoxide doggo lazygit rip2)
for _pkg in "${legacy_packages[@]}"; do
    if dpkg -l "${_pkg}" 2>/dev/null | grep -q "^ii"; then
        info "Removing dpkg package ${_pkg}"
        sudo apt-get remove -y "${_pkg}" || warning "Could not remove ${_pkg}"
    fi
done

success "Legacy binary cleanup complete"

_safeExit_
{{- end }}
