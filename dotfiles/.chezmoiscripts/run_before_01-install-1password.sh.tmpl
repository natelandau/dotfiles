{{- if and .use_secrets (not .is_synology) -}}
#!/usr/bin/env bash

{{ template "shared_script_utils.bash" . }}

# Secrets clients read 1Password items via `onepasswordRead` during apply, which
# aborts if `op` is absent. This run_before script runs before any target file,
# so it guarantees `op` exists before the first secret is read.
if command -v op &>/dev/null; then
    success "1Password CLI (op) already installed"
    _safeExit_ 0
fi

header "🔐  Installing 1Password CLI (op)"

{{ if eq .chezmoi.os "darwin" }}
# Formula only; the `1password` desktop cask is handled by the packages script.
brew install 1password-cli
{{ end }}

{{ if eq .chezmoi.os "linux" }}
# Only apt-based Linux can self-install here; a non-apt host would abort the
# whole apply under set -e, so warn and continue instead.
if ! command -v apt-get &>/dev/null; then
    warning "1Password CLI is missing and apt-get was not found; install op manually."
    _safeExit_ 0
fi

# Headless CLI only: the official 1Password apt repo, arch-detected so amd64 and
# arm64 hosts both resolve. --yes on gpg so a prior failed run's keyring is
# overwritten rather than aborting on "File exists".
arch="$(dpkg --print-architecture)"

notice "Adding 1Password apt repository"
curl -sS https://downloads.1password.com/linux/keys/1password.asc \
    | sudo gpg --yes --dearmor --output /usr/share/keyrings/1password-archive-keyring.gpg

echo "deb [arch=${arch} signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/${arch} stable main" \
    | sudo tee /etc/apt/sources.list.d/1password.list >/dev/null

# debsig verification policy the 1password-cli package requires to install.
sudo mkdir -p /etc/debsig/policies/AC2D62742012EA22/
curl -sS https://downloads.1password.com/linux/debian/debsig/1password.pol \
    | sudo tee /etc/debsig/policies/AC2D62742012EA22/1password.pol >/dev/null
sudo mkdir -p /usr/share/debsig/keyrings/AC2D62742012EA22
curl -sS https://downloads.1password.com/linux/keys/1password.asc \
    | sudo gpg --yes --dearmor --output /usr/share/debsig/keyrings/AC2D62742012EA22/debsig.gpg

header "Installing 1password-cli"
sudo apt update
sudo apt install -y 1password-cli
{{ end }}

_safeExit_
{{- end }}
