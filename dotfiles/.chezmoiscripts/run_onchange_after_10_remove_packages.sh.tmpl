#!/usr/bin/env bash

{{ template "shared_script_utils.bash" . }}


header "Checking for packages to remove"

did_remove_package=false

{{ if and (eq .chezmoi.os "darwin") (lookPath "brew") }}

    {{ range $package := .packages.homebrew.to_remove }}
    # Match the package name exactly; a substring grep matches unrelated kegs/casks (e.g. "redis" vs "another-redis-desktop-manager").
    if brew list --formula "{{ $package }}" &> /dev/null || brew list --cask "{{ $package }}" &> /dev/null; then
        did_remove_package=true
        brew uninstall "{{ $package }}" || warning "Failed to uninstall {{ $package }}"
    fi

    {{ end }}
{{ end }}


UV_PATH="$(_uvBinaryPath_)" || {
    warning "uv is not installed"
}


# header "removing python packages with uv"
{{ range $package := .packages.python.to_remove }}
if [[ -n ${UV_PATH} ]]; then
    # Match the tool name in column one exactly; a bare substring grep also matches version strings and executable lines.
    if ${UV_PATH} tool list 2>/dev/null | awk '{print $1}' | grep -qx "{{ $package }}"; then
        did_remove_package=true
        ${UV_PATH} tool uninstall "{{ $package }}" || warning "Failed to uninstall {{ $package }}"
    fi
fi
{{ end }}


{{- if eq .chezmoi.os "linux" }}
    # Remove apt packages listed in packages.apt.to_remove (e.g. tools migrated to mise).
    {{- range $package := .packages.apt.to_remove }}
    if dpkg-query -W -f='${Status}' "{{ $package }}" 2>/dev/null | grep -q "install ok installed"; then
        did_remove_package=true
        sudo apt-get remove -y "{{ $package }}"
    fi
    {{- end }}

    # Drop the eza custom apt repo + keyring now that eza is managed by mise on Linux.
    if [[ -f /etc/apt/sources.list.d/gierens.list || -f /etc/apt/keyrings/gierens.gpg ]]; then
        sudo rm -f /etc/apt/sources.list.d/gierens.list /etc/apt/keyrings/gierens.gpg
        did_remove_package=true
    fi

    # Remove the old batcat/fdfind compatibility symlinks; mise now provides real bat/fd.
    for _link in bat fd; do
        if [[ -L "${HOME}/.local/bin/${_link}" ]]; then
            rm -f "${HOME}/.local/bin/${_link}"
            did_remove_package=true
        fi
    done
{{- end }}

if ${did_remove_package}; then
    success "Removed packages"
fi

_safeExit_
